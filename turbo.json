{
  "$schema": "https://turborepo.org/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "cache": false,
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "build/**"
      ]
    },
    "dev": {
      "cache": false,
      "outputs": [],
      "env": [
        "NODE_ENV"
      ],
      "persistent": true
    },
    "devlti": {
      "cache": false,
      "outputs": [],
      "env": [
        "NODE_ENV"
      ],
      "persistent": true
    },
    "devturbo": {
      "cache": false,
      "persistent": true
    },
    "dev:seed": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "start": {
      "cache": false,
      "dependsOn": [
        "^start"
      ]
    }
  },
  "globalEnv": [
    "PORT",
    "NODE_ENV",
    "SITE_TITLE",
    "ANALYTICS_ENABLED",
    "CONTACT_SUBMISSION_FROM_ADDRESS",
    "RECAPTCHA_ENABLED",
    "NEXT_PUBLIC_RECAPTCHA_ENABLED",
    "RECAPTCHA_MANDATORY",
    "NEXT_PUBLIC_RECAPTCHA_MANDATORY",
    "RECAPTCHA_SITE_KEY",
    "NEXT_PUBLIC_RECAPTCHA_SITE_KEY",
    "RECAPTCHA_SECRET_KEY",
    "DATABASE_URI",
    "DATA_REQUEST_CACHING",
    "NEXT_BUILD",
    "S3_BUCKET",
    "S3_CDN_DOMAIN",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "SESSION_SECRET",
    "SMTP_HOST",
    "SMTP_USER",
    "SMTP_PASSWORD",
    "PUBLIC_WEBSITE_URL",
    "PLAYWRIGHT_TEST_BASE_URL"
  ]
}