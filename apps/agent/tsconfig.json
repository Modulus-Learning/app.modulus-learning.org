{
  "compilerOptions": {
    "lib": ["es2024", "dom"],
    "target": "es2024",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"]
    },
    "strict": true
  },
  "include": ["src/index.ts", "src", "test"],
  "exclude": ["node_modules", "dist", "demo", "coverage"]
}
