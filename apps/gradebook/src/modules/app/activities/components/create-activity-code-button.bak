'use client'
import { MouseEventHandler, startTransition, useActionState } from 'react'

import { Button, LoaderEllipsis } from '@infonomic/uikit/react'

import type { ActivityCodeFormState } from '../@types'
import { createActivityCode } from '../create-activity-code'

const initialState: ActivityCodeFormState = { errors: {}, status: 'idle' }

type Status = 'busy' | 'available' | 'not-available' | 'idle'

export function CreateActivityCodeButton() {
  const [formState, formAction, isPending] = useActionState(createActivityCode, initialState)

  const handleOnClick = () => {
    const data = new FormData()
    startTransition(() => {
      formAction(data)
    })
  }

  return (
    <Button onClick={handleOnClick} intent="primary" variant="outlined" className="min-w-[180px]">
      {isPending === true ? (
        <LoaderEllipsis size={30} color="#aaaaaa" />
      ) : (
        <span>Create Activity Code</span>
      )}
    </Button>
  )
}
