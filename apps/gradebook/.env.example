PORT=3000

NEXT_PUBLIC_SITE_NAME=Modulus
NEXT_PUBLIC_SITE_DESCRIPTION='Modulus - an open source educational analytics system for distributed learning content.'
NEXT_PUBLIC_PUBLIC_SERVER_URL=http://localhost:3000

NEXT_PUBLIC_CSP_ENABLED=false
DATA_REQUEST_CACHING=true
ANALYTICS_ENABLED=false

SESSION_SECRET=[generate-a-random-secret]

ADMIN_SESSION_COOKIE_NAME=admin_session
ADMIN_SESSION_COOKIE_SAME_SITE=lax
ADMIN_SESSION_COOKIE_HTTP_ONLY=true
ADMIN_SESSION_COOKIE_SECURE=false

ADMIN_REFRESH_COOKIE_NAME=admin_refresh
ADMIN_REFRESH_COOKIE_SAME_SITE=lax
ADMIN_REFRESH_COOKIE_HTTP_ONLY=true
ADMIN_REFRESH_COOKIE_SECURE=false

USER_SESSION_COOKIE_NAME=user_session
USER_SESSION_COOKIE_SAME_SITE=lax
USER_SESSION_COOKIE_HTTP_ONLY=true
USER_SESSION_COOKIE_SECURE=false

USER_REFRESH_COOKIE_NAME=user_refresh
USER_REFRESH_COOKIE_SAME_SITE=lax
USER_REFRESH_COOKIE_HTTP_ONLY=true
USER_REFRESH_COOKIE_SECURE=false

FLASH_COOKIE_NAME=flash
FLASH_COOKIE_SAME_SITE=lax
FLASH_COOKIE_HTTP_ONLY=true
FLASH_COOKIE_SECURE=false

API_BASE_URL=http://localhost:3010/api
API_JWT_PUBLIC_KEY=[base64-encoded-public-key]
API_JWT_ISSUER=localhost:3010
API_JWT_AUDIENCE=localhost:3010

NEXT_PUBLIC_RECAPTCHA_ENABLED=false
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=[recaptcha-site-key]
NEXT_PUBLIC_RECAPTCHA_MANDATORY=false
RECAPTCHA_SECRET_KEY=[recaptcha-secret-key]
GOOGLE_APPLICATION_CREDENTIALS=google-service-account-key.json
GOOGLE_APPLICATION_PROJECT_ID=[google-cloud-project-id]
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

SYSTEM_EMAIL_FROM_ADDRESS='Modulus Learning <info@example.com>'
CONTACT_SUBMISSION_FROM_ADDRESS='Modulus Learning <info@example.com>'

EMAIL_DEBUG_ONLY=false
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

S3_ACCESS_KEY_ID=[s3-access-key-id]
S3_SECRET_ACCESS_KEY=[s3-secret-access-key]
S3_BUCKET=[s3-bucket-name]
S3_CDN_DOMAIN=https://cdn.example.com

OAUTH_GITHUB_CLIENT_ID=[github-oauth-client-id]
OAUTH_GITHUB_CLIENT_SECRET=[github-oauth-client-secret]
OAUTH_GITHUB_AUTH_URL=https://github.com/login/oauth/authorize
OAUTH_GITHUB_ACCESS_TOKEN_URL=https://github.com/login/oauth/access_token
OAUTH_GITHUB_USER_URL=https://api.github.com/user
OAUTH_GITHUB_RETURN_URL=http://localhost:3000/routes/oauth/github

OAUTH_GOOGLE_CLIENT_ID=[google-oauth-client-id]
OAUTH_GOOGLE_CLIENT_SECRET=[google-oauth-client-secret]
OAUTH_GOOGLE_AUTH_URL=https://accounts.google.com/o/oauth2/auth
OAUTH_GOOGLE_ACCESS_TOKEN_URL=https://oauth2.googleapis.com/token
OAUTH_GOOGLE_RETURN_URL=http://localhost:3000/routes/oauth/google

POSTGRES_CONNECTION_STRING=postgres://username:password@127.0.0.1:5432/database_name

LTI_REDIRECT_URI=http://localhost:3000/routes/lti/launch
LTI_JWKS_KEY_ID=[lti-jwks-key-id]
LTI_JWKS_PRIVATE_KEY=[base64-encoded-private-key]
LTI_JWKS_PUBLIC_KEY=[base64-encoded-public-key]

SERVER_HOST=localhost:3000
SERVER_BASE_URL=http://localhost:3000
API_JWT_PRIVATE_KEY=[base64-encoded-private-key]

API_JWT_ACCESS_TOKEN_EXPIRES_IN=600
# API_JWT_ACCESS_TOKEN_EXPIRES_IN=1h
API_JWT_REFRESH_TOKEN_EXPIRES_IN=2592000
# API_JWT_REFRESH_TOKEN_EXPIRES_IN=100h

