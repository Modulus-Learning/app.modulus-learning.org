{
  "name": "@modulus-learning/gradebook",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules .next build dist .turbo",
    "dev": "cross-env NODE_OPTIONS='--no-deprecation' next dev --turbopack | pino-pretty --colorize",
    "devlti": "cross-env NODE_OPTIONS='--no-deprecation --use-openssl-ca' next dev --turbopack -H modulus.infonomic.local --experimental-https --experimental-https-key ./certs/local.key --experimental-https-cert ./certs/local.crt | pino-pretty --colorize",
    "devturbo": "cross-env NODE_OPTIONS=--no-deprecation next dev --turbo",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=6144\" next build",
    "build:webpack": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=6144\" next build --webpack",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "biome check --write --unsafe --diagnostic-level=error",
    "generate:types": "payload generate:types",
    "standalone-script": "tsx ./src/scripts/standalone-script.ts",
    "test": "vitest --mode=jsdom",
    "test:jsdom": "vitest --mode=jsdom",
    "test:node": "vitest --mode=node"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@base-ui/react": "^1.4.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@formatjs/intl-localematcher": "^0.8.3",
    "@google-cloud/recaptcha-enterprise": "^6.4.0",
    "@hookform/resolvers": "^5.2.2",
    "@infonomic/crypto": "^2.3.0",
    "@infonomic/schemas": "^2.4.0",
    "@infonomic/uikit": "^6.7.0",
    "@modulus-learning/core": "workspace:*",
    "@panva/hkdf": "^1.2.1",
    "argon2": "^0.44.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "classnames": "^2.5.1",
    "cookie": "^1.1.1",
    "cross-env": "^10.1.0",
    "escape-html": "^1.0.3",
    "googleapis": "^171.4.0",
    "intl-messageformat": "^11.2.1",
    "jose": "^6.2.2",
    "jsdom": "^29.0.2",
    "json-schema": "^0.4.0",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "negotiator": "^1.0.0",
    "newrelic": "^13.19.1",
    "next": "16.2.4",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.5",
    "react-cookie": "^8.1.0",
    "react-dom": "19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.72.1",
    "react-intersection-observer": "^10.0.3",
    "react-share": "^5.3.0",
    "react-swipeable": "^7.0.2",
    "recharts": "^3.8.1",
    "serialize-error": "^13.0.1",
    "slugify": "^1.6.9",
    "tailwind-merge": "^3.5.0",
    "undici": "^8.1.0",
    "unique-names-generator": "^4.7.1",
    "uuid": "^14.0.0",
    "zod": "^4.3.6",
    "zod-form-data": "^3.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@next/env": "16.2.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bcrypt": "^6.0.0",
    "@types/escape-html": "^1.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/json-schema": "^7.0.15",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "cssnano": "^7.1.5",
    "dotenv": "^17.4.2",
    "postcss": "^8.5.10",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  }
}
