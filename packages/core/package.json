{
  "name": "@modulus-learning/core",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/public/tokens.d.ts",
      "import": "./dist/public/tokens.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "chokidar 'src/**/*' -c 'npm-run-all build'",
    "devlti": "chokidar 'src/**/*' -c 'npm-run-all build'",
    "build": "tsc -p tsconfig.json && tsc-alias",
    "lint": "biome check --write --unsafe --diagnostic-level=error",
    "clean": "rimraf node_modules dist build .turbo",
    "test": "LOG_LEVEL=off tsx --env-file=.env --test $(find . -name \"*.test.ts\")",
    "test:one": "LOG_LEVEL=off tsx --no-warnings --env-file=.env --test",
    "drizzle:generate": "tsc -p tsconfig.json && drizzle-kit generate --config=drizzle.config.ts",
    "drizzle:push": "tsc -p tsconfig.json && drizzle-kit push --config=drizzle.config.ts",
    "drizzle:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "drizzle:drop": "drizzle-kit drop --config=drizzle.config.ts",
    "drizzle:seed": "tsx --no-warnings --env-file=.env ./src/database/seeds/index.ts"
  },
  "dependencies": {
    "@infonomic/schemas": "^2.4.0",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "googleapis": "^171.4.0",
    "handlebars": "^4.7.9",
    "jose": "^6.2.2",
    "nodemailer": "^8.0.5",
    "nodemailer-html-to-text": "^3.2.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "unique-names-generator": "^4.7.1",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@faker-js/faker": "^10.4.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/nodemailer-html-to-text": "^3.1.3",
    "@types/pg": "^8.20.0",
    "chokidar": "^5.0.0",
    "chokidar-cli": "^3.0.0",
    "drizzle-kit": "^0.31.10",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
